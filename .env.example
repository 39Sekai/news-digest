# Daily News Digest v2 - Environment Configuration
# Copy this file to .env and fill in your values

# Discord Bot Configuration (Required)
DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=1475330217215004904

# Database Configuration (Optional - uses defaults if not set)
# DATABASE_PATH=data/news_digest.db

# Logging Configuration (Optional)
# LOG_LEVEL=INFO
# LOG_DIR=data/logs

# Feed Configuration (Optional)
# MAX_ARTICLE_AGE_HOURS=48
# STALE_FEED_HOURS=168
# MAX_FEED_ERRORS=5

# Scoring Configuration (Optional)
# TOP_N_LIMIT=10
# DEDUPE_THRESHOLD=0.85
